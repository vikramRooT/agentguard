# ============================================================================
# AgentGuard environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ---------------------------------------------------------------------------
# Circle Developer API
# Get from: https://developers.circle.com -> sign up with hackathon email
# ---------------------------------------------------------------------------
CIRCLE_API_KEY=TEST_API_KEY:replace_me
CIRCLE_ENTITY_SECRET=replace_me
CIRCLE_WALLET_SET_ID=
CIRCLE_ENV=sandbox

# ---------------------------------------------------------------------------
# Arc testnet settlement
# RPC + explorer URLs per https://docs.arc.network/arc/tutorials/deploy-on-arc
# USDC contract per https://docs.arc.network/arc/references/contract-addresses
# ---------------------------------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_BLOCK_EXPLORER=https://testnet.arcscan.app
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000

# Circle contracts deployed on Arc Testnet
ARC_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
ARC_GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
ARC_CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA

# ERC-8004 registry (deployed by us on Day 3 — address recorded here after deploy)
ARC_ERC8004_IDENTITY_REGISTRY=
ARC_ERC8004_REPUTATION_REGISTRY=
ARC_ERC8004_VALIDATION_REGISTRY=

# AgentGuard's own SpendingLimiter contract (deployed Day 3)
ARC_AGENTGUARD_SPENDING_LIMITER=

# ---------------------------------------------------------------------------
# AgentGuard protocol economics
# ---------------------------------------------------------------------------
AGENTGUARD_FEE_PER_CHECK_USDC=0.0001
AGENTGUARD_TREASURY_WALLET_ID=

# ---------------------------------------------------------------------------
# Intent classifier — pick ONE provider. Anthropic Haiku 4.5 is the default.
# ---------------------------------------------------------------------------
INTENT_CLASSIFIER_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional alternates
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AIMLAPI_KEY=

# ---------------------------------------------------------------------------
# Database + pub/sub (docker compose brings these up locally)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://agentguard:agentguard@localhost:5432/agentguard
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# API + web service URLs
# ---------------------------------------------------------------------------
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# ---------------------------------------------------------------------------
# Demo wallets (populated by `pnpm seed`)
# ---------------------------------------------------------------------------
DEMO_RESEARCH_AGENT_WALLET_ID=
DEMO_DATA_VENDOR_AGENT_WALLET_ID=
DEMO_SMS_AGENT_WALLET_ID=
DEMO_INFERENCE_AGENT_WALLET_ID=
DEMO_COMPROMISED_AGENT_WALLET_ID=
DEMO_OPERATOR_WALLET_ID=
DEMO_ATTACKER_WALLET_ADDRESS=0x9999999999999999999999999999999999999999
